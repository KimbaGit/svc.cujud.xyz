# Salin file ini menjadi .env dan isi dengan nilai dari Supabase
# cp .env.example .env

# Dari Supabase: Project Settings → Database → Connection string → URI
# Gunakan mode "Session" (port 5432)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres?pgbouncer=true"

# Gunakan mode "Direct" (port 5432, tanpa pgbouncer)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres"
